#!/usr/bin/env bash
# Git post-merge hook - 在合并上游代码后自动运行健康检查
# 
# 作用：
# 1. 检测合并后本地功能是否被意外覆盖
# 2. 如果检查失败，提醒开发者立即处理
# 3. 不会阻止合并，只是给出警告

set -e

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "🔍 运行合并后健康检查..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# 检查是否是从上游合并
if git log -1 --format=%s | grep -q "upstream\|merge.*main"; then
  echo "检测到上游合并，执行本地功能健康检查..."
  echo ""
  
  # 运行健康检查
  if command -v pnpm &> /dev/null; then
    pnpm check:health || {
      echo ""
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      echo "⚠️  健康检查失败！请立即检查本地功能是否被覆盖。"
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      echo ""
      exit 0  # 不阻止合并，只是警告
    }
  else
    echo "⚠️  pnpm 未安装，跳过健康检查"
  fi
else
  echo "✓ 非上游合并，跳过健康检查"
fi

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "✅ 合并后检查完成"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
