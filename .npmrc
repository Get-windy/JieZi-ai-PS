# 使用官方源（主源）- 确保所有包可用
registry=https://registry.npmjs.org/

# 特定大包使用国内镜像加速
# @lancedb:registry=https://registry.npmmirror.com/
# @img:registry=https://registry.npmmirror.com/
# sharp:registry=https://registry.npmmirror.com/

# 备用源配置（手动切换时使用）
# registry=https://registry.npmmirror.com/
# registry=https://registry.npm.taobao.org/
# registry=https://mirrors.huaweicloud.com/repository/npm/
# registry=https://mirrors.cloud.tencent.com/npm/

allow-build-scripts=@whiskeysockets/baileys,sharp,esbuild,protobufjs,fs-ext,node-pty,@lydell/node-pty,@matrix-org/matrix-sdk-crypto-nodejs,node-llama-cpp,@napi-rs/canvas,@xpack-dev-tools/cmake

# node-llama-cpp 配置：优先使用预编译二进制文件
node_llama_cpp_skip_download=false
node_llama_cpp_gpu=false

# 强制使用 HTTPS 代替 SSH（解决 Git SSH 权限问题）
# pnpm 会自动将 git+ssh:// 转换为 https://
git-shallow-hosts[]=github.com
git-shallow-hosts[]=gitlab.com
git-shallow-hosts[]=bitbucket.org
